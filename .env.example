# .env.example — copy to .env and fill in your values
# Used by python-dotenv (loaded automatically if you call load_dotenv() or
# if you run `streamlit run app.py` with the dotenv plugin).

# ─── Model ───────────────────────────────────────────────────────────────────
MODEL_PATH=weights/best.pt
DEVICE=cuda               # cuda | cpu

# ─── Detection ───────────────────────────────────────────────────────────────
CONF_THRESH=0.50
IMG_SIZE=640
LINE_POS=0.15             # Counting line at 15 % from top of frame

# ─── Camera ──────────────────────────────────────────────────────────────────
CAMERA_INDEX=0

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=quality_control
DB_USER=postgres
DB_PASSWORD=Zach5461
